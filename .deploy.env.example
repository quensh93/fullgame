DEPLOY_SSH_HOST=YOUR_SERVER_IP_OR_HOST
DEPLOY_SSH_USER=root
DEPLOY_SSH_PORT=1310
DEPLOY_REMOTE_DIR=/root/fullgame
DEPLOY_ENV_FILE=.env.prod
DEPLOY_BUILD_BACKEND=true
DEPLOY_BUILD_FRONTEND=true
DEPLOY_SSH_KEY_PATH=$HOME/.ssh/id_ed25519
DEPLOY_SSH_ADD_TO_AGENT=true
DEPLOY_BOOTSTRAP_SSH_KEY=true
DEPLOY_SSH_CONTROL_PERSIST=10m
DEPLOY_SSH_PASSWORD_FALLBACK=true
DEPLOY_FORCE_PASSWORD_AUTH=false
DEPLOY_REMOTE_PULL_RETRIES=4
DEPLOY_BACKEND_RUNTIME_BASE_IMAGE=docker.arvancloud.ir/eclipse-temurin:17-jre-jammy
DEPLOY_FRONTEND_RUNTIME_BASE_IMAGE=docker.arvancloud.ir/nginx:1.27-alpine
