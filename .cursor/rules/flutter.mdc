### Repository Pattern
```dart
class FeatureRepository {
  final ApiManager _apiManager;
  
  FeatureRepository(this._apiManager);
  
  Future<Model> getData() async {
    try {
      final response = await _apiManager.get('/api/endpoint');
      return Model.fromJson(response);
    } catch (e) {
      throw ApiException(message: 'Error loading data', originalError: e);
    }
  }
}
```

