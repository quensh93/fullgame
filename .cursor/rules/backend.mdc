## 🔧 الگوهای توسعه

### Controller Pattern
```java
@RestController
@RequestMapping("/api/feature")
@RequiredArgsConstructor
@Tag(name = "Feature", description = "توضیح عملکرد")
public class FeatureController {

    private final FeatureService featureService;

    @Operation(summary = "توضیح endpoint", description = "جزئیات عملکرد")
    @GetMapping("/endpoint")
    public ResponseEntity<ResponseType> getData(
        @RequestParam String param,
        @AuthenticationPrincipal UserDetailsImpl userDetails
    ) {
        var result = featureService.getData(param, userDetails.getUser());
        return ResponseEntity.ok(result);
    }
}
```

### Service Pattern
```java
@Service
@RequiredArgsConstructor
@Transactional
public class FeatureService {

    private final FeatureRepository featureRepository;
    private final OtherService otherService;

    public ResponseType createData(CreateRequest request, User user) {
        // Validation
        validateRequest(request);
        
        // Business logic
        Entity entity = Entity.builder()
            .field1(request.getField1())
            .field2(request.getField2())
            .createdBy(user)
            .build();
        
        // Save
        Entity saved = featureRepository.save(entity);
        
        // Additional operations
        otherService.performOperation(saved);
        
        return buildResponse(saved);
    }

    private void validateRequest(CreateRequest request) {
        if (request.getField1() == null) {
            throw new IllegalArgumentException("Field1 is required");
        }
    }

    private ResponseType buildResponse(Entity entity) {
        return ResponseType.builder()
            .id(entity.getId())
            .field1(entity.getField1())
            .build();
    }
}
```

### Repository Pattern
```java
@Repository
public interface FeatureRepository extends JpaRepository<Entity, Long> {
    
    Optional<Entity> findByField1(String field1);
    
    List<Entity> findByStatusAndCreatedAtAfter(Status status, LocalDateTime date);
    
    @Query("SELECT e FROM Entity e WHERE e.field1 = :field1 AND e.status = :status")
    List<Entity> findByCustomQuery(@Param("field1") String field1, @Param("status") Status status);
    
    @Modifying
    @Query("UPDATE Entity e SET e.status = :status WHERE e.id = :id")
    void updateStatus(@Param("id") Long id, @Param("status") Status status);
}
```

### Entity Pattern
```java
@Entity
@Table(name = "entities")
@Data
@NoArgsConstructor
@AllArgsConstructor
@Builder
public class Entity {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(nullable = false, unique = true)
    private String field1;

    @Column(nullable = false)
    private String field2;

    @Enumerated(EnumType.STRING)
    private Status status;

    @ManyToOne
    private User createdBy;

    @Column(nullable = false)
    private LocalDateTime createdAt;

    @PrePersist
    protected void onCreate() {
        createdAt = LocalDateTime.now();
    }

    @PreUpdate
    protected void onUpdate() {
        // Update logic if needed
    }
}
```

