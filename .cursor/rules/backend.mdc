### Unit Testing
```java
@ExtendWith(MockitoExtension.class)
class FeatureServiceTest {

    @Mock
    private FeatureRepository featureRepository;

    @InjectMocks
    private FeatureService featureService;

    @Test
    void shouldCreateEntitySuccessfully() {
        // Given
        CreateRequest request = new CreateRequest("test");
        Entity entity = Entity.builder().field1("test").build();
        when(featureRepository.save(any())).thenReturn(entity);

        // When
        ResponseType result = featureService.create(request, user);

        // Then
        assertThat(result.getField1()).isEqualTo("test");
        verify(featureRepository).save(any());
    }
}
```

