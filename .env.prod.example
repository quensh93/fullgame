# Required
APP_DOMAIN=game.example.com
DB_NAME=gameapp
DB_USERNAME=gameapp
DB_PASSWORD=change-this-db-password
JWT_SECRET=change-this-jwt-secret-with-a-long-random-value

# Optional
COMPOSE_PROJECT_NAME=gameapp
APP_VERSION=1.0.0
JWT_EXPIRATION=86400000
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.0
HOST_BACKEND_PORT=18080
HOST_FRONTEND_PORT=18081
GEOIP_ENABLED=false
WS_MIN_SUPPORTED_APP_VERSION=3.0.0
REDIS_ENABLED=true
REDIS_REQUIRE_HEALTHY=false
FF_REDIS_ENABLED=true
FF_REDIS_SESSION_PRESENCE_ENABLED=true
FF_REDIS_IDEMPOTENCY_ENABLED=false
FF_REDIS_RATE_LIMIT_ENABLED=false
FF_REDIS_PUB_SUB_ENABLED=true
FF_REDIS_ROOM_ACTION_LOCK_ENABLED=false
